using System;

namespace BookingSystem
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("##### KONTORNORD - BOOKINGSYSTEM #####");
            Console.WriteLine("1. Book et mødelokale");
            Console.WriteLine("2. Tjek Kalenderen");
            Console.WriteLine("3. Afslut");

            Console.Write("Vælg en mulighed: ");
            string choice = Console.ReadLine();

            switch (choice)
            {
                case "1":
                    BookMeetingRoom();
                    break;
                case "2":
                    Console.WriteLine("Se Kalenderen");
                    break;
                case "3":
                    Console.WriteLine("Programmet Afsluttes");
                    break;
                default:
                    Console.WriteLine("Ugyldigt valg");
                    break;
            }
        }

        static void BookMeetingRoom()
        {
            Console.WriteLine("Book mødelokale");
            Console.WriteLine("Tilgængelige mødelokaler:");
            Console.WriteLine("1. Mødelokale A");
            Console.WriteLine("2. Mødelokale B");
            Console.WriteLine("3. Mødelokale C");

            string room = "";
            while (true)
            {
                Console.Write("Vælg et mødelokale (1-3): ");
                string roomChoice = Console.ReadLine();

                if (roomChoice == "1")
                {
                    room = "Mødelokale A";
                    break;
                }
                else if (roomChoice == "2")
                {
                    room = "Mødelokale B";
                    break;
                }
                else if (roomChoice == "3")
                {
                    room = "Mødelokale C";
                    break;
                }
                else
                {
                    Console.WriteLine("Ugyldigt valg. Prøv igen.");
                }
            }

            // Vælg Medarbejder
            Console.Write("Indtast Medarbejdernavn: ");
            string name = Console.ReadLine();

            // Vælg dato
            Console.Write("Indtast dato (dd-mm-yyyy): ");
            string date = Console.ReadLine();

            // Vælg tidsrum
            Console.Write("Indtast starttidspunkt (hh:mm): ");
            string startTime = Console.ReadLine();

            Console.Write("Indtast sluttidspunkt (hh:mm): ");
            string endTime = Console.ReadLine();

            // Bekræft booking
            Console.WriteLine("\n ##### BOOKING BEKRÆFTELSE #####");
            Console.WriteLine($"Medarbejder: {name}");
            Console.WriteLine($"Mødelokale: {room}");
            Console.WriteLine($"Dato: {date}");
            Console.WriteLine($"Tid: {startTime} - {endTime}");
        }
    }
}
